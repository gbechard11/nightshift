TELEGRAM_BOT_TOKEN=put-token-here
ALLOWED_USERS=

# --- WhatsApp via Twilio (optional) ---
# Leave these unset and the WhatsApp path stays dormant; Telegram is unaffected.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Sandbox sender is whatsapp:+14155238886 ; a registered sender is your own number.
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Comma-separated allowlist of permitted senders, e.g. whatsapp:+17805551234
ALLOWED_WHATSAPP=
# Local port the webhook binds to (127.0.0.1 only; tunnel bridges to it).
WHATSAPP_WEBHOOK_PORT=8770
WHATSAPP_WEBHOOK_PATH=/whatsapp
# Public https URL the Cloudflare tunnel exposes, e.g. https://abc.trycloudflare.com
# Required for Twilio signature validation; if unset, falls back to allowlist only.
WHATSAPP_PUBLIC_URL=

# --- Employee bot (separate Telegram bot: employee_bot.py) ---
# A locked-down Pedro for Nightshift staff. Its OWN token + allowlist, runs as
# nightshift-employees.service. Every run is restricted (no shell/file tools ->
# cannot read .env or any VPS file); web research stays on; each employee gets an
# isolated, memory-keeping session. Create a NEW bot via @BotFather for the token.
EMPLOYEE_BOT_TOKEN=
# Comma-separated Telegram user IDs allowed to use it. Empty = nobody (fails closed).
EMPLOYEE_USERS=
# Optional overrides (defaults shown):
# EMPLOYEE_WORKDIR=/data/employees
# EMPLOYEE_SESSION_DIR=/data/employees/sessions
# EMPLOYEE_ALLOWED_TOOLS=WebSearch WebFetch

# --- Prism.fm (live-music booking platform, optional) ---
# Leave PRISM_REFRESH_TOKEN unset and the whole Prism path stays dormant.
# Prism has no public API; we reuse the web app's own backend. Auth is AWS
# Cognito. From a logged-in app.prism.fm browser, open DevTools console and run
#   localStorage.getItem('refreshToken')
# then paste that value here. Pedro mints short-lived access tokens from it
# automatically (no app secret needed). NOTE: logging out of Prism in that
# browser revokes the refresh token — grab a fresh one if Pedro reports it's
# rejected. Default Cognito lifetime is ~30 days.
PRISM_REFRESH_TOKEN=
# Usually leave these at the defaults baked into prism.py:
# PRISM_COGNITO_CLIENT_ID=3pdck2a6f3o3gua1sjvfsvqjfo
# PRISM_COGNITO_REGION=us-east-2
# The API version-pins requests. If Pedro reports "Version_Mismatch", set this to
# the backend version named in the error and restart.
# PRISM_APP_VERSION=1.0.618
# New-booking watcher (scripts/prism_watch.py, run by cron):
# PRISM_WATCH_DAYS=180
# REPORT_TG_CHAT_ID=   # who gets Prism alerts + ad digests; defaults to ALLOWED_USERS
