TELEGRAM_BOT_TOKEN=put-token-here
ALLOWED_USERS=

# --- WhatsApp via Twilio (optional) ---
# Leave these unset and the WhatsApp path stays dormant; Telegram is unaffected.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Sandbox sender is whatsapp:+14155238886 ; a registered sender is your own number.
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Comma-separated allowlist of permitted senders, e.g. whatsapp:+17805551234
ALLOWED_WHATSAPP=
# Local port the webhook binds to (127.0.0.1 only; tunnel bridges to it).
WHATSAPP_WEBHOOK_PORT=8770
WHATSAPP_WEBHOOK_PATH=/whatsapp
# Public https URL the Cloudflare tunnel exposes, e.g. https://abc.trycloudflare.com
# Required for Twilio signature validation; if unset, falls back to allowlist only.
WHATSAPP_PUBLIC_URL=

# --- Employee bot (separate Telegram bot: employee_bot.py) ---
# A locked-down Pedro for Nightshift staff. Its OWN token + allowlist, runs as
# nightshift-employees.service. Every run is restricted (no shell/file tools ->
# cannot read .env or any VPS file); web research stays on; each employee gets an
# isolated, memory-keeping session. Create a NEW bot via @BotFather for the token.
EMPLOYEE_BOT_TOKEN=
# Comma-separated Telegram user IDs allowed to use it. Empty = nobody (fails closed).
EMPLOYEE_USERS=
# Optional overrides (defaults shown):
# EMPLOYEE_WORKDIR=/data/employees
# EMPLOYEE_SESSION_DIR=/data/employees/sessions
# EMPLOYEE_ALLOWED_TOOLS=WebSearch WebFetch
