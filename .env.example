TELEGRAM_BOT_TOKEN=put-token-here
ALLOWED_USERS=

# --- WhatsApp via Twilio (optional) ---
# Leave these unset and the WhatsApp path stays dormant; Telegram is unaffected.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Sandbox sender is whatsapp:+14155238886 ; a registered sender is your own number.
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Comma-separated allowlist of permitted senders, e.g. whatsapp:+17805551234
ALLOWED_WHATSAPP=
# Local port the webhook binds to (127.0.0.1 only; tunnel bridges to it).
WHATSAPP_WEBHOOK_PORT=8770
WHATSAPP_WEBHOOK_PATH=/whatsapp
# Public https URL the Cloudflare tunnel exposes, e.g. https://abc.trycloudflare.com
# Required for Twilio signature validation; if unset, falls back to allowlist only.
WHATSAPP_PUBLIC_URL=

# --- Employee bot (separate Telegram bot: employee_bot.py) ---
# A locked-down Pedro for Nightshift staff. Its OWN token + allowlist, runs as
# nightshift-employees.service. Every run is restricted (no shell/file tools ->
# cannot read .env or any VPS file); web research stays on; each employee gets an
# isolated, memory-keeping session. Create a NEW bot via @BotFather for the token.
EMPLOYEE_BOT_TOKEN=
# Comma-separated Telegram user IDs allowed to use it. Empty = nobody (fails closed).
EMPLOYEE_USERS=
# Optional overrides (defaults shown):
# EMPLOYEE_WORKDIR=/data/employees
# EMPLOYEE_SESSION_DIR=/data/employees/sessions
# EMPLOYEE_ALLOWED_TOOLS=WebSearch WebFetch

# --- Prism.fm (live-music booking platform, optional) ---
# Leave both PRISM_* tokens unset and the whole Prism path stays dormant.
# Prism has no public API; we reuse the web app's own backend (AWS Cognito auth).
#
# WORKING METHOD — paste an ACCESS TOKEN (lasts ~24h, re-paste when it expires):
#   In a logged-in app.prism.fm browser, DevTools console:  localStorage.getItem('token')
#   Paste it here. This is the path Pedro actually uses today.
PRISM_ACCESS_TOKEN=
# NOTE on auto-refresh: Prism's Cognito app client is CONFIDENTIAL (has a client
# secret we don't hold), so Pedro cannot mint fresh access tokens from a refresh
# token. PRISM_REFRESH_TOKEN below is therefore NOT usable on its own and is kept
# only in case Prism later exposes a public client or official API. The durable
# fix is official Prism API access (email support@prism.fm).
PRISM_REFRESH_TOKEN=
# Usually leave these at the defaults baked into prism.py:
# PRISM_COGNITO_CLIENT_ID=3pdck2a6f3o3gua1sjvfsvqjfo
# PRISM_COGNITO_REGION=us-east-2
# The API version-pins requests. If Pedro reports "Version_Mismatch", set this to
# the backend version named in the error and restart.
# PRISM_APP_VERSION=1.0.618
# New-booking watcher (scripts/prism_watch.py, run by cron):
# PRISM_WATCH_DAYS=180
# REPORT_TG_CHAT_ID=   # who gets Prism alerts + ad digests; defaults to ALLOWED_USERS

# === Meta multi-account profiles ===
# Comma list of ad-account profiles you can launch ads from (see /accounts in the bot).
# 'nightshift' uses the bare META_ACCESS_TOKEN/META_AD_ACCOUNT_ID/META_PAGE_ID/META_PIXEL_ID above.
# Each additional key <K> reads: META_<K>_ACCESS_TOKEN, META_<K>_AD_ACCOUNT_ID,
#   META_<K>_PAGE_ID, META_<K>_PIXEL_ID, META_<K>_CURRENCY, META_<K>_LABEL, META_<K>_COUNTRIES.
# Each profile needs its OWN System User token (generated in the Business Manager that
# owns that ad account + Page, with those assets assigned). Discover ids with:
#   python scripts/find_meta_assets.py @<key>
META_PROFILES=nightshift,pawnshop
META_PAWNSHOP_LABEL=Pawn Shop Live
META_PAWNSHOP_ACCESS_TOKEN=
META_PAWNSHOP_AD_ACCOUNT_ID=
META_PAWNSHOP_PAGE_ID=
META_PAWNSHOP_PIXEL_ID=
META_PAWNSHOP_CURRENCY=CAD
META_PAWNSHOP_COUNTRIES=CA
